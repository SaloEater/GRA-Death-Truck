; DLTX patch — adds [death_truck] physic wreck section
; Targets: configs/models/dynamic_objects.ltx (vanilla)
; Base parent: [physic_object]

[death_truck]:physic_object
$spawn       = "wrecks\death_truck"
$prefetch    = 32
cform        = skeleton
visual      = dynamics\vehicles\veh_zil_130\veh_zil_u_01.ogf
;fixed_bones  = root
remove_time  = 0
destroyable  = false

; DLTX patch — adds loot-source NPC squad descriptors (spawned, killed, looted, deleted)
; Targets: configs/misc/squad_descr/squad_descr_raid_events.ltx

[raid_event_loot_stalker_single]:online_offline_group
faction      = stalker
npc_random   = sim_default_stalker_0, sim_default_stalker_1, sim_default_stalker_1
npc_in_squad = 1, 1
common       = true

[raid_event_loot_monolith_single]:online_offline_group
faction      = monolith
npc_random   = sim_default_monolith_3, sim_default_monolith_3, sim_default_monolith_4
npc_in_squad = 1, 1
common       = true
